#!/usr/bin/env bash
# Improved railpack stub: if a package.json with a build script exists,
# run the build (using yarn) and then create a Dockerfile that serves the
# built `dist` output. Otherwise fall back to serving the project root.
set -euo pipefail
args=("$@")
TAG=""
# parse -t <tag>
for i in "${!args[@]}"; do
  if [[ "${args[$i]}" == "-t" && $((i+1)) -lt ${#args[@]} ]]; then
    TAG="${args[$((i+1))]}"
  fi
done
if [[ -z "$TAG" ]]; then
  echo "railpack: no -t tag provided" >&2
  exit 1
fi
pwd=$(pwd)
echo "railpack: building tag $TAG in $pwd"

# If package.json exists and has a build script, try to build using yarn
if [[ -f package.json ]] && grep -q '"build"' package.json; then
  echo "railpack: detected package.json with build script — running build"
  # Use corepack/yarn if available in environment
  if command -v corepack >/dev/null 2>&1; then
    corepack enable || true
    corepack prepare yarn@3.5.0 --activate || true
  fi
  if command -v yarn >/dev/null 2>&1; then
    echo "railpack: running yarn install && yarn build"
    yarn install --frozen-lockfile --silent || yarn install --silent || true
    yarn build || echo "railpack: yarn build failed, continuing to create image"
  else
    echo "railpack: yarn not found, skipping build step"
  fi
fi

# Choose what to copy into the image: prefer dist/ if present
if [[ -d dist ]]; then
  echo "railpack: found dist/ — will serve built files"
  cat > "$pwd/Dockerfile.railpack" <<EOF
FROM python:3.11-slim
COPY dist /app
WORKDIR /app
EXPOSE 8080
CMD ["python","-m","http.server","8080"]
EOF
else
  echo "railpack: no dist/ — serving project root"
  cat > "$pwd/Dockerfile.railpack" <<'EOF'
FROM python:3.11-slim
COPY . /app
WORKDIR /app
EXPOSE 8080
CMD ["python","-m","http.server","8080"]
EOF
fi

# build
echo "docker build -f Dockerfile.railpack -t $TAG ."
docker build -f Dockerfile.railpack -t "$TAG" .
rc=$?
if [[ $rc -ne 0 ]]; then
  echo "railpack: docker build failed with code $rc" >&2
  exit $rc
fi
echo "railpack: build complete -> $TAG"
# cleanup Dockerfile.railpack
rm -f "$pwd/Dockerfile.railpack"
exit 0
